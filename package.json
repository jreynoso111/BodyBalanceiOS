{
  "name": "body-balance-ios",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "start:dev-client": "expo start --dev-client",
    "ios": "expo run:ios",
    "ios:release": "expo run:ios --configuration Release",
    "ios:release:sim": "bash ./scripts/run-ios-release-sim.sh",
    "ios:device": "expo run:ios --device",
    "test": "jest --runInBand",
    "test:critical": "jest --runInBand --coverage=false",
    "typecheck": "tsc --noEmit",
    "doctor": "npx expo-doctor",
    "verify:release": "npm run test:critical && npm run typecheck && npm run doctor",
    "deploy:admin-user-management": "supabase functions deploy admin-user-management --no-verify-jwt",
    "deploy:google-play-sync": "supabase functions deploy google-play-sync --no-verify-jwt"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.28",
    "@supabase/supabase-js": "^2.98.0",
    "base64-arraybuffer": "^1.0.2",
    "d3-array": "^3.2.4",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.19",
    "expo": "~55.0.5",
    "expo-constants": "~55.0.7",
    "expo-dev-client": "~55.0.16",
    "expo-device": "~55.0.9",
    "expo-file-system": "~55.0.10",
    "expo-font": "~55.0.4",
    "expo-iap": "^3.4.9",
    "expo-image-picker": "~55.0.12",
    "expo-linear-gradient": "~55.0.8",
    "expo-linking": "~55.0.7",
    "expo-local-authentication": "~55.0.8",
    "expo-notifications": "~55.0.12",
    "expo-print": "~55.0.8",
    "expo-router": "~55.0.5",
    "expo-secure-store": "^55.0.8",
    "expo-sharing": "~55.0.11",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.9",
    "expo-web-browser": "~55.0.9",
    "lucide-react-native": "^0.575.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-calendars": "^1.1314.0",
    "react-native-chart-kit": "^6.12.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/d3-array": "^3.2.2",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.8",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
